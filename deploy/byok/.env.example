# WhiteSpace BYOK — copy to .env and fill in your values

WHITESPACE_MODE=byok

# OpenRouter — single key gives access to all providers
OPENROUTER_API_KEY=

# Neo4j (Aura or local Docker instance)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Search APIs (optional — falls back to DuckDuckGo if not provided)
EXA_API_KEY=
FIRECRAWL_API_KEY=

# LangSmith (optional — pipeline tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=false
